# Changes require a restart to take effect.

# Ensure R2-D2 bins are in the path
export R2D2_PATH=$HOME/.local/share/r2-d2
export PATH=$R2D2_PATH/bin:$PATH

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate nvm if present
[[ -s "${NVM_DIR:-$HOME/.nvm}/nvm.sh" ]] && source "${NVM_DIR:-$HOME/.nvm}/nvm.sh"
[[ -d /usr/local/go/bin ]] && export PATH=$PATH:/usr/local/go/bin
