#!/bin/bash

# Remove a development environment that was previously installed via omarchy-install-dev-env.
# Usage: omarchy-remove-dev-env <node|bun|deno|go|python|elixir|zig|rust>

if [[ -z $1 ]]; then
  echo "Usage: omarchy-remove-dev-env <node|bun|deno|go|python|elixir|zig|rust>" >&2
  exit 1
fi

case "$1" in
node)
  echo -e "Removing Node.js (nvm)...\n"
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [[ -s $NVM_DIR/nvm.sh ]]; then
    source "$NVM_DIR/nvm.sh"
    def=$(nvm version default 2>/dev/null)
    [[ -n $def ]] && nvm uninstall "$def" 2>/dev/null || true
    nvm alias default '' 2>/dev/null || true
  fi
  ;;
bun)
  echo -e "Removing Bun...\n"
  omarchy-pkg-drop bun
  ;;
deno)
  echo -e "Removing Deno...\n"
  omarchy-pkg-drop deno
  ;;
go)
  echo -e "Removing Go (/usr/local/go)...\n"
  sudo rm -rf /usr/local/go
  sudo rm -f /etc/profile.d/go.sh
  ;;
python)
  echo -e "Removing Python (packages) and uv...\n"
  omarchy-pkg-drop python
  rm -rf ~/.local/bin/uv ~/.local/bin/uvx ~/.cargo/bin/uv 2>/dev/null || true
  ;;
elixir)
  echo -e "Removing Elixir/Erlang...\n"
  omarchy-pkg-drop elixir erlang
  ;;
zig)
  echo -e "Removing Zig...\n"
  omarchy-pkg-drop zls-git 2>/dev/null || true
  omarchy-pkg-drop zig
  ;;
rust)
  echo -e "Removing Rust...\n"
  rustup self uninstall -y 2>/dev/null || true
  ;;
*)
  echo "Unknown environment: $1" >&2
  exit 1
  ;;
esac

echo -e "\nDone!"
