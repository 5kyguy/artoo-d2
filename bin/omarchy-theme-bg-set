#!/bin/bash

# Sets the specified image as the default background (single-theme setup).
# Used by the menu background selector; cycles through backgrounds/.

if [[ -z $1 ]]; then
  echo "Usage: omarchy-theme-bg-set <path-to-image>" >&2
  exit 1
fi

BACKGROUND="$1"
OMARCHY_ROOT="${OMARCHY_PATH:-$HOME/.local/share/omarchy}"
DEFAULT_BACKGROUND="$OMARCHY_ROOT/background"

# Create symlink to the new background
ln -nsf "$BACKGROUND" "$DEFAULT_BACKGROUND"

# Kill existing swaybg and start new one
pkill -x swaybg
setsid uwsm-app -- swaybg -i "$DEFAULT_BACKGROUND" -m fill >/dev/null 2>&1 &
