#!/bin/bash

# Overwrite the user config for the Plymouth drive decryption and boot sequence with the R2-D2 default and rebuild it.

sudo cp ~/.local/share/r2-d2/default/plymouth/* /usr/share/plymouth/themes/r2-d2/
sudo plymouth-set-default-theme r2-d2

if command -v limine-mkinitcpio &>/dev/null; then
  sudo limine-mkinitcpio
else
  sudo mkinitcpio -P
fi
