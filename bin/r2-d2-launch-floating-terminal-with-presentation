#!/bin/bash

# Launch a floating terminal with the R2-D2 logo presentation, then execute the command passed in, and finally end with the r2-d2-show-done presentation.
# Used by actions such as Update System.

cmd="$*"
exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.r2d2.terminal --title=R2-D2 -e bash -c "r2-d2-show-logo; $cmd; if (( \$? != 130 )); then r2-d2-show-done; fi"
