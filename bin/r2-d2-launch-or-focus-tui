#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like r2-d2-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.r2d2.$(basename "$1")"
LAUNCH_COMMAND="r2-d2-launch-tui $*"

exec r2-d2-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
