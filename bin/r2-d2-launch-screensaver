#!/bin/bash

# Launch the R2-D2 screensaver in the default terminal on the system with the correct font configuration.

# Exit early if we don't have the tte show
if ! command -v tte &>/dev/null; then
  exit 1
fi

# Exit early if screensave is already running
pgrep -f org.r2d2.screensaver && exit 0

# Allow screensaver to be turned off but also force started
if [[ -f ~/.local/state/r2-d2/toggles/screensaver-off ]] && [[ $1 != "force" ]]; then
  exit 1
fi

# Silently quit Walker on overlay
walker -q

focused=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')
terminal=$(xdg-terminal-exec --print-id)

for m in $(hyprctl monitors -j | jq -r '.[] | .name'); do
  hyprctl dispatch focusmonitor $m

  case $terminal in
  *Alacritty*)
    hyprctl dispatch exec -- \
      alacritty --class=org.r2d2.screensaver \
      --config-file ~/.config/alacritty/screensaver.toml \
      -e r2-d2-cmd-screensaver
    ;;
  *ghostty*)
    hyprctl dispatch exec -- \
      ghostty --class=org.r2d2.screensaver \
      --config-file=~/.config/ghostty/screensaver \
      --font-size=18 \
      -e r2-d2-cmd-screensaver
    ;;
  *)
    notify-send "✋  Screensaver only runs in Alacritty or Ghostty"
    ;;
  esac
done

hyprctl dispatch focusmonitor $focused
