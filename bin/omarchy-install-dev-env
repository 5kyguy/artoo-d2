#!/bin/bash

# Install one of the supported development environments. Usually called via Install > Development > * in the Omarchy Menu.

if [[ -z $1 ]]; then
  echo "Usage: omarchy-install-dev-env <node|bun|deno|go|python|elixir|rust|zig>" >&2
  exit 1
fi

install_node() {
  echo -e "Installing Node.js via nvm...\n"
  export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
  if [[ ! -d $NVM_DIR ]]; then
    curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash
  fi
  if [[ -s $NVM_DIR/nvm.sh ]]; then
    source "$NVM_DIR/nvm.sh"
    nvm install --lts
    nvm alias default 'lts/*'
  fi
}

case "$1" in
node)
  install_node
  ;;
bun)
  echo -e "Installing Bun...\n"
  omarchy-pkg-add bun
  ;;
deno)
  echo -e "Installing Deno...\n"
  omarchy-pkg-add deno
  ;;
go)
  echo -e "Installing Go (official tarball to /usr/local)...\n"
  GO_VERSION=1.26.0
  GO_TAR="go${GO_VERSION}.linux-amd64.tar.gz"
  sudo rm -rf /usr/local/go
  curl -sL "https://go.dev/dl/${GO_TAR}" | sudo tar -C /usr/local -xz
  echo 'export PATH=$PATH:/usr/local/go/bin' | sudo tee /etc/profile.d/go.sh >/dev/null
  ;;
python)
  echo -e "Installing Python...\n"
  omarchy-pkg-add python
  echo -e "\nInstalling uv...\n"
  curl -fsSL https://astral.sh/uv/install.sh | sh
  ;;
elixir)
  echo -e "Installing Elixir...\n"
  omarchy-pkg-add erlang elixir
  mix local.hex --force 2>/dev/null || true
  ;;
rust)
  echo -e "Installing Rust...\n"
  bash -c "$(curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs)" -- -y
  ;;
zig)
  echo -e "Installing Zig...\n"
  omarchy-pkg-add zig
  omarchy-pkg-aur-add zls-git 2>/dev/null || true
  ;;
*)
  echo "Unknown environment: $1" >&2
  exit 1
  ;;
esac
