#!/bin/bash

# Install one of the approved terminals and set it as the default for R2-D2 (Super + Return etc).

if (($# == 0)); then
  echo "Usage: r2-d2-install-terminal [alacritty|ghostty]"
  exit 1
fi

package="$1"

# Map package name to desktop entry ID
case "$package" in
alacritty) desktop_id="Alacritty.desktop" ;;
ghostty) desktop_id="com.mitchellh.ghostty.desktop" ;;
*)
  echo "Unknown terminal: $package"
  exit 1
  ;;
esac

# Install package
if r2-d2-pkg-add $package; then
  # Copy custom desktop entry with X-TerminalArg* keys for xdg-terminal-exec
  mkdir -p ~/.local/share/applications
  if [[ $package == "alacritty" ]]; then
    cp "$R2D2_PATH/applications/Alacritty.desktop" ~/.local/share/applications/
  elif [[ $package == "ghostty" ]]; then
    cp "$R2D2_PATH/applications/com.mitchellh.ghostty.desktop" ~/.local/share/applications/
  fi

  # Update xdg-terminals.list to prioritize the proper terminal
  cat >~/.config/xdg-terminals.list <<EOF
# Terminal emulator preference order for xdg-terminal-exec
# The first found and valid terminal will be used
$desktop_id
EOF
else
  echo "Failed to install $package"
fi
