#!/bin/bash

# Overwrite the user configs for the Walker application launcher (which also powers the Omarchy Menu) and restart the services.

# Ensure walker is set to autostart
mkdir -p ~/.config/autostart/
cp "${OMARCHY_PATH:-$HOME/.local/share/omarchy}/config/walker/walker.desktop" ~/.config/autostart/

# And restarts if it crashes or is killed
mkdir -p ~/.config/systemd/user/app-walker@autostart.service.d/
cp "${OMARCHY_PATH:-$HOME/.local/share/omarchy}/config/walker/restart.conf" ~/.config/systemd/user/app-walker@autostart.service.d/restart.conf

systemctl --user daemon-reload

# Refresh configs
omarchy-refresh-config walker/config.toml
omarchy-refresh-config elephant/calc.toml
omarchy-refresh-config elephant/desktopapplications.toml
omarchy-refresh-config elephant/menus/omarchy_background_selector.lua

# Restart service
omarchy-restart-walker
